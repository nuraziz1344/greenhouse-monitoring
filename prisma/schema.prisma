generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

model Telemetry {
    id           BigInt    @id @default(autoincrement())
    soilMoisture Float     @map("soil_moisture")
    recordedAt   DateTime? @map("recorded_at")
    createdAt    DateTime  @default(now()) @map("created_at")

    @@map("telemetry")
}
