generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

model Telemetry {
    id           BigInt    @id @default(autoincrement())
    sensorId     Int       @default(1) @map("sensor_id") // physical sensor unit (1..N, see runtimeConfig.public.soilSensors)
    soilMoisture Float     @map("soil_moisture")
    recordedAt   DateTime? @map("recorded_at")
    createdAt    DateTime  @default(now()) @map("created_at")

    // Dedup guard: the same reading can arrive twice (BLE re-sync after a lost
    // ack, or WiFi single-post + BLE batch overlap). Inserts use skipDuplicates.
    // Includes sensorId so two sensors reporting the same value at the same
    // instant aren't mistaken for a duplicate of each other.
    @@unique([sensorId, recordedAt, soilMoisture])
    @@index([sensorId])
    @@map("telemetry")
}

// Single-row (id=1) device-wide settings, seeded on first GET /api/config and
// pushed to the ESP32 over BLE together with the schedules.
model DeviceConfig {
    id                     Int      @id @default(1)
    measureIntervalMinutes Int      @default(15) @map("measure_interval_minutes")
    lowMoistureThreshold   Float    @default(40) @map("low_moisture_threshold")
    updatedAt              DateTime @updatedAt @map("updated_at")

    @@map("device_config")
}

// A physical water-pump relay channel. Seeded (1 row per configured channel)
// on first read via /api/relay. `isOn` holds the last-known desired state.
model Relay {
    id        BigInt   @id @default(autoincrement())
    channel   Int      @unique // physical relay index (1..3)
    name      String // e.g. "Zone A"
    isOn      Boolean  @default(false) @map("is_on")
    updatedAt DateTime @updatedAt @map("updated_at")
    createdAt DateTime @default(now()) @map("created_at")

    @@map("relay")
}

// A recurring daily watering window for a relay. Source of truth for schedules;
// pushed to the ESP32 over BLE and also enacted in-app while the dashboard is open.
model Schedule {
    id              BigInt   @id @default(autoincrement())
    relayChannel    Int      @map("relay_channel") // references Relay.channel
    startTime       String   @map("start_time") // "HH:MM" 24h, local time
    durationMinutes Int      @map("duration_minutes") // how long to run
    daysOfWeek      Int[]    @default([0, 1, 2, 3, 4, 5, 6]) @map("days_of_week") // 0=Sun..6=Sat
    enabled         Boolean  @default(true)
    createdAt       DateTime @default(now()) @map("created_at")

    @@map("schedule")
}

// Append-only history of relay on/off actuations.
model ActuationLog {
    id           BigInt   @id @default(autoincrement())
    relayChannel Int      @map("relay_channel")
    action       String // "on" | "off"
    source       String // "manual" | "schedule" | "device"
    recordedAt   DateTime @default(now()) @map("recorded_at")

    @@map("actuation_log")
}
