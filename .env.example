# ─── Database ───────────────────────────────────────────
# Postgres Config
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=greenhouse_monitoring
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Prisma ORM config
DATABASE_URL="prisma+postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# ─── Alerting ───────────────────────────────────────────
# Webhook URL for low-soil-moisture notifications (Telegram Bot, WhatsApp, etc.)
# Optional — alerts are logged server-side if not set
ALERT_WEBHOOK_URL=""
