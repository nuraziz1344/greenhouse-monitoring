# ─── Database ───────────────────────────────────────────
# Postgres Config
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=greenhouse_monitoring
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Prisma ORM config
DATABASE_URL="prisma+postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# ─── Alerting ───────────────────────────────────────────
# Webhook URL for low-soil-moisture notifications (Telegram Bot, WhatsApp, etc.)
# Optional — alerts are logged server-side if not set
ALERT_WEBHOOK_URL=""

# ─── Dashboard Polling ───────────────────────────────────
# Telemetry data fetch interval (milliseconds, default: 30000 = 30s)
NUXT_PUBLIC_TELEMETRY_POLL_INTERVAL=30000

# Status badge update interval (milliseconds, default: 1000 = 1s)
NUXT_PUBLIC_STATUS_BADGE_INTERVAL=1000

# ESP32 disconnect timeout (milliseconds, default: 120000 = 2min)
# better same with the ESP32's send interval
NUXT_PUBLIC_ESP32_DISCONNECT_TIMEOUT=120000
