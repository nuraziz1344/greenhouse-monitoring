# ─── Database ───────────────────────────────────────────
# Postgres Config
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=greenhouse_monitoring
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Prisma ORM config
DATABASE_URL="postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# ─── Alerting ───────────────────────────────────────────
# Webhook URL for low-soil-moisture notifications (Telegram Bot, WhatsApp, etc.)
# Optional — alerts are logged server-side if not set
ALERT_WEBHOOK_URL=""

# ─── Dashboard Polling ───────────────────────────────────
# Telemetry data fetch interval (milliseconds, default: 30000 = 30s)
NUXT_PUBLIC_TELEMETRY_POLL_INTERVAL=30000

# Status badge update interval (milliseconds, default: 1000 = 1s)
NUXT_PUBLIC_STATUS_BADGE_INTERVAL=1000

# How fresh the newest reading must be for the header badge to show the ESP32
# as online via WiFi (milliseconds, default: 1200000 = 20m — firmware posts
# every 15m, plus slack for a late post)
NUXT_PUBLIC_DEVICE_ONLINE_THRESHOLD=1200000

# ─── BLE Configuration ───────────────────────────────────
# BLE device name advertised by ESP32 (used as requestDevice filter)
NUXT_PUBLIC_BLE_DEVICE_NAME=GH-Sensor
